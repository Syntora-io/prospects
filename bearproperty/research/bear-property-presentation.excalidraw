      "isDeleted": false,
      "boundElements": null,
      "updated": 1709500000000,
      "link": null,
      "locked": false,
      "text": "\"we're putting like a little 40 or 50 or 60 next to their name so that when\nwe go back to try to place someone off our waiting list, we can go, okay,\nlet's sort it all by the 40s, start at the top of the 40 list\"",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"we're putting like a little 40 or 50 or 60 next to their name so that when\nwe go back to try to place someone off our waiting list, we can go, okay,\nlet's sort it all by the 40s, start at the top of the 40 list\"",
      "autoResize": true,
      "lineHeight": 1.25,
      "frameId": null
    },
