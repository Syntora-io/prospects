      "versionNonce": 983297493,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1709500000000,
      "link": null,
      "locked": false,
      "text": "\"our software can't have someone fill out an application and then determine\nthis person qualifies for a 40% unit... it needs someone to actually open\nthat application, do a quick hand calculation on what they've entered as\ntheir income, and do like a best guess\"",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"our software can't have someone fill out an application and then determine\nthis person qualifies for a 40% unit... it needs someone to actually open\nthat application, do a quick hand calculation on what they've entered as\ntheir income, and do like a best guess\"",
      "autoResize": true,
      "lineHeight": 1.25,
      "frameId": null
    },
